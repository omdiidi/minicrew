# --- Supabase ---
# REST URL for PostgREST calls (ends in .supabase.co)
SUPABASE_URL=https://your-project.supabase.co
# Service-role key (secret; never commit). Used by worker to read/write queue tables.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Supabase direct Postgres URL ---
# REQUIRED for the reaper's advisory lock. MUST be the DIRECT connection on port 5432,
# NOT the pooler URL (port 6543). Find in: Supabase Dashboard → Project Settings → Database → Connection string.
# Format: postgresql://postgres.<project_ref>:<password>@<direct-host>:5432/postgres
SUPABASE_DB_URL=postgresql://...

# --- Consumer config ---
# Absolute path to the consumer project's worker-config/ directory.
MINICREW_CONFIG_PATH=/absolute/path/to/your-project/worker-config
